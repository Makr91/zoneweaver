#!/bin/bash
set -e

case "$1" in
    remove)
        # Keep user, data, and config for potential reinstall
        echo "Hyperweaver Server removed but user and data preserved"
        ;;
    purge)
        # Remove everything including user and data
        echo "Purging Hyperweaver Server completely..."
        
        # Remove system user
        if getent passwd hyperweaver-server > /dev/null 2>&1; then
            deluser hyperweaver-server || true
        fi
        
        # Remove data directories (user confirmation should happen via apt/dpkg)
        rm -rf /var/lib/hyperweaver-server
        rm -rf /var/log/hyperweaver-server
        rm -rf /etc/hyperweaver-server
        
        echo "Hyperweaver Server completely removed"
        ;;
    upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        # Do nothing for these cases
        ;;
    *)
        echo "postrm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

# Reload systemd daemon
systemctl daemon-reload || true

#DEBHELPER#
